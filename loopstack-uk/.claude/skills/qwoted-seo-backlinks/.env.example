# Optional defaults the skill scripts will pick up.
# Most users do NOT need to set these — the skill works with cookies only.

# Friendly label printed in logs / saved pitches (any string).
QWOTED_EMAIL=you@example.com

# Optional: where to keep the cookie jar + per-account state.
# Defaults to ~/.qwoted on Mac/Linux, %USERPROFILE%\.qwoted on Windows.
# QWOTED_HOME=/Users/yourname/.qwoted
